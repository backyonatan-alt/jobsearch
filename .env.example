# Server
PORT=8080
BASE_URL=http://localhost:8080
BRAND_NAME=Pursuit

# Postgres
DATABASE_URL=postgres://postgres:dev@localhost:5432/jobsearch_dev?sslmode=disable

# Sessions
SESSION_COOKIE_NAME=pursuit_session
SESSION_TTL_HOURS=720

# Magic links
MAGIC_LINK_TTL_MINUTES=15

# Mail: "log" prints links to stdout (dev). "smtp" and "postmark" wired in v0.2.
MAIL_DRIVER=log
MAIL_FROM=no-reply@pursuit.local

# Anthropic (used in v0.2 for dossier; leave blank in v0.1)
ANTHROPIC_API_KEY=

# Closed beta gate: comma-separated allow-list of emails. Empty = anyone can request.
ALLOWED_EMAILS=
