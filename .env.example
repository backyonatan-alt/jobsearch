# Server
PORT=8080
BASE_URL=http://localhost:8080
BRAND_NAME=Pursuit

# Postgres
DATABASE_URL=postgres://postgres:dev@localhost:5432/jobsearch_dev?sslmode=disable

# Sessions
SESSION_COOKIE_NAME=pursuit_session
SESSION_TTL_HOURS=720

# Google OAuth (create at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Anthropic (used in v0.2 for dossier; leave blank in v0.1)
ANTHROPIC_API_KEY=

# Closed beta gate: comma-separated allow-list of emails (bootstrap only —
# once seeded into the DB, invites are managed via /admin/people). Empty = open.
ALLOWED_EMAILS=

# Comma-separated emails to auto-promote to is_admin on sign-in / on boot.
ADMIN_EMAILS=

# Bearer token for machine-to-machine /api/ops/* routes (e.g. the
# beta-interest-alert cron). Generate a random string; set the SAME value as
# the GitHub Actions secret OPS_TOKEN. Empty = ops routes 404 (disabled).
OPS_TOKEN=

# GA4 web-stream Measurement ID (G-XXXXXXX). Empty = no analytics: the gtag
# snippet is only injected server-side when this is set, so dev/local emit
# nothing. Set in prod (/opt/jobsearch/.env) once the GA4 property exists.
GA4_MEASUREMENT_ID=
